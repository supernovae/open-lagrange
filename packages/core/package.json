{
  "name": "@open-lagrange/core",
  "version": "0.1.0",
  "description": "Core runtime boundary, reconciliation schemas, and Hatchet workflows for Open Lagrange.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./interface": {
      "types": "./dist/interface.d.ts",
      "import": "./dist/interface.js"
    },
    "./planning": {
      "types": "./dist/planning/index.d.ts",
      "import": "./dist/planning/index.js"
    },
    "./secrets": {
      "types": "./dist/secrets/index.d.ts",
      "import": "./dist/secrets/index.js"
    },
    "./repository": {
      "types": "./dist/repository/index.d.ts",
      "import": "./dist/repository/index.js"
    },
    "./skills": {
      "types": "./dist/skills/index.d.ts",
      "import": "./dist/skills/index.js"
    },
    "./artifacts": {
      "types": "./dist/artifacts/index.d.ts",
      "import": "./dist/artifacts/index.js"
    },
    "./demos": {
      "types": "./dist/demos/index.d.ts",
      "import": "./dist/demos/index.js"
    },
    "./doctor": {
      "types": "./dist/doctor/index.d.ts",
      "import": "./dist/doctor/index.js"
    },
    "./packs": {
      "types": "./dist/packs/index.d.ts",
      "import": "./dist/packs/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:worker": "tsx src/hatchet/worker.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@hatchet-dev/typescript-sdk": "^1.21.2",
    "@open-lagrange/capability-sdk": "file:../capability-sdk",
    "ai": "^6.0.168",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  }
}
