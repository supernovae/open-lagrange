{
  "name": "@open-lagrange/core",
  "version": "0.1.0",
  "description": "Core runtime boundary, reconciliation schemas, and Hatchet workflows for Open Lagrange.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./interface": {
      "types": "./dist/interface.d.ts",
      "import": "./dist/interface.js"
    },
    "./planning": {
      "types": "./dist/planning/index.d.ts",
      "import": "./dist/planning/index.js"
    },
    "./planning-web": {
      "types": "./dist/planning/web-api.d.ts",
      "import": "./dist/planning/web-api.js"
    },
    "./secrets": {
      "types": "./dist/secrets/index.d.ts",
      "import": "./dist/secrets/index.js"
    },
    "./approval": {
      "types": "./dist/approval/approval-token.d.ts",
      "import": "./dist/approval/approval-token.js"
    },
    "./repository": {
      "types": "./dist/repository/index.d.ts",
      "import": "./dist/repository/index.js"
    },
    "./skills": {
      "types": "./dist/skills/index.d.ts",
      "import": "./dist/skills/index.js"
    },
    "./artifacts": {
      "types": "./dist/artifacts/index.d.ts",
      "import": "./dist/artifacts/index.js"
    },
    "./demos": {
      "types": "./dist/demos/index.d.ts",
      "import": "./dist/demos/index.js"
    },
    "./doctor": {
      "types": "./dist/doctor/index.d.ts",
      "import": "./dist/doctor/index.js"
    },
    "./packs": {
      "types": "./dist/packs/index.d.ts",
      "import": "./dist/packs/index.js"
    },
    "./model-providers": {
      "types": "./dist/model-providers/index.d.ts",
      "import": "./dist/model-providers/index.js"
    },
    "./chat-pack": {
      "types": "./dist/chat-pack/index.d.ts",
      "import": "./dist/chat-pack/index.js"
    },
    "./research": {
      "types": "./dist/research/index.d.ts",
      "import": "./dist/research/index.js"
    },
    "./output": {
      "types": "./dist/capability-packs/output/index.d.ts",
      "import": "./dist/capability-packs/output/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./runs": {
      "types": "./dist/runs/index.d.ts",
      "import": "./dist/runs/index.js"
    },
    "./search": {
      "types": "./dist/search/index.d.ts",
      "import": "./dist/search/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js"
    },
    "./storage": {
      "types": "./dist/storage/state-store.d.ts",
      "import": "./dist/storage/state-store.js"
    },
    "./evals": {
      "types": "./dist/evals/index.d.ts",
      "import": "./dist/evals/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:worker": "tsx src/hatchet/worker.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@hatchet-dev/typescript-sdk": "^1.21.2",
    "@open-lagrange/capability-sdk": "file:../capability-sdk",
    "@types/sanitize-html": "^2.16.1",
    "ai": "^6.0.168",
    "jszip": "^3.10.1",
    "marked": "^18.0.3",
    "sanitize-html": "^2.17.3",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  }
}
